[plugins]

ai_assistant_hub/llm_api="ollama_api"
ai_assistant_hub/preferences/thinking_target=0
ai_assistant_hub/preferences/skip_greeting=false
ai_assistant_hub/preferences/always_scroll_to_bottom=false

[rendering]

textures/canvas_textures/default_texture_filter=3
textures/canvas_textures/default_texture_repeat=2
anti_aliasing/quality/msaa_2d=3
anti_aliasing/quality/msaa_3d=3
scaling_3d/mode=2
scaling_3d/scale=0.77
scaling_3d/fsr_sharpness=0.2
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
anti_aliasing/quality/screen_space_aa=2
anti_aliasing/quality/use_taa=true
occlusion_culling/use_occlusion_culling=true
mesh_lod/lod_change/threshold_pixels=2.0

[xr]

shaders/enabled=true
